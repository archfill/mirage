# Maintainer: archfill
pkgname=mirage-cloud
pkgver=$(grep '^version' "$startdir/../Cargo.toml" | head -1 | sed 's/.*"\(.*\)"/\1/')
pkgrel=1
pkgdesc="Linux cloud file sync client with on-demand FUSE filesystem"
arch=('x86_64')
url="https://github.com/archfill/mirage"
license=('MIT')
depends=('fuse3' 'qt6-base' 'kio')
makedepends=('rust' 'cargo' 'cmake' 'extra-cmake-modules' 'qt6-base' 'kio')
source=()

build() {
    cd "$startdir/.."
    # Reset all flags set by makepkg to avoid linker issues with aws-lc-sys.
    # makepkg's CFLAGS/LDFLAGS interfere with aws-lc-sys's internal cmake build.
    unset CARGO_ENCODED_RUSTFLAGS
    unset CFLAGS CXXFLAGS LDFLAGS RUSTFLAGS
    cargo build --release
    cmake -B build-dolphin -S plugins/dolphin \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build build-dolphin
}

package() {
    cd "$startdir/.."
    install -Dm755 target/release/mirage "$pkgdir/usr/bin/mirage"
    DESTDIR="$pkgdir" cmake --install build-dolphin
    install -Dm644 dist/mirage.service "$pkgdir/usr/lib/systemd/user/mirage.service"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Shell completions
    local _outdir
    _outdir=$(find target/release/build/mirage-* -name "mirage.bash" -printf '%h' -quit)
    install -Dm644 "$_outdir/mirage.bash" "$pkgdir/usr/share/bash-completion/completions/mirage"
    install -Dm644 "$_outdir/_mirage" "$pkgdir/usr/share/zsh/site-functions/_mirage"
    install -Dm644 "$_outdir/mirage.fish" "$pkgdir/usr/share/fish/vendor_completions.d/mirage.fish"

    # Man page
    install -Dm644 "$_outdir/mirage.1" "$pkgdir/usr/share/man/man1/mirage.1"

    # Desktop files
    install -Dm644 dist/mirage-tray.desktop "$pkgdir/etc/xdg/autostart/mirage-tray.desktop"
    install -Dm644 dist/mirage.desktop "$pkgdir/usr/share/applications/mirage.desktop"

    # Icon
    install -Dm644 dist/mirage.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/mirage.svg"

    # Default mirageignore
    install -Dm644 dist/mirageignore.default "$pkgdir/usr/share/mirage/mirageignore.default"
}
